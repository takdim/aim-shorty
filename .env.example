# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this-in-production

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aim_shorty
DB_USER=root
DB_PASSWORD=your-db-password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Email (Flask-Mail) ───────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=LinkCraft <your-email@gmail.com>

# ─── Midtrans ────────────────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxx
MIDTRANS_IS_PRODUCTION=false

# ─── DOKU Payment Gateway ────────────────────────────────────────────────────
DOKU_MERCHANT_ID=your-doku-merchant-id
DOKU_API_KEY=your-doku-api-key
DOKU_API_SECRET=your-doku-api-secret
DOKU_CLIENT_ID=your-doku-client-id
DOKU_IS_PRODUCTION=false

# ─── iPaymu Payment Gateway ──────────────────────────────────────────────────
IPAYMU_VA=your-ipaymu-va
IPAYMU_API_KEY=your-ipaymu-api-key
IPAYMU_IS_PRODUCTION=false

# ─── Pakasir Payment Gateway ─────────────────────────────────────────────────
PAKASIR_PROJECT_SLUG=your-pakasir-project-slug
PAKASIR_API_KEY=your-pakasir-api-key
PAKASIR_IS_PRODUCTION=false
PAKASIR_BASE_URL=https://app.pakasir.com

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Google Safe Browsing ─────────────────────────────────────────────────────
GOOGLE_SAFE_BROWSING_API_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5000
MAX_CONTENT_LENGTH=5242880
